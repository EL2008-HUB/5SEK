APP_ENV=staging
NODE_ENV=production
PORT=3000
JWT_SECRET=staging-secret
DATABASE_URL=postgres://user:password@staging-db:5432/fivesek_staging
SECRETS_FILE=/mnt/secrets-store/5sek-api-staging.json
CORS_ALLOWED_ORIGINS=https://staging-app.5sek.app
INLINE_BACKGROUND_WORKER=false
INLINE_INJECTION_WORKER=false
REQUIRE_HTTPS=true
MEDIA_CDN_BASE_URL=https://staging-cdn.5sek.app
LOG_FORMAT=json
BACKUP_RETENTION_DAYS=7
