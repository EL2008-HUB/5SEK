APP_ENV=production
NODE_ENV=production
PORT=3000
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_JWT_SECRET_32_PLUS_CHARS
DATABASE_URL=postgres://REPLACE_DB_USER:REPLACE_DB_PASSWORD@REPLACE_DB_HOST:5432/REPLACE_DB_NAME
SECRETS_FILE=/mnt/secrets-store/5sek-api-production.json
CORS_ALLOWED_ORIGINS=https://app.5sek.app
INLINE_BACKGROUND_WORKER=false
INLINE_INJECTION_WORKER=false
REQUIRE_HTTPS=true
APP_PUBLIC_URL=https://app.5sek.app
MEDIA_CDN_BASE_URL=https://res.cloudinary.com/REPLACE_CLOUDINARY_CLOUD_NAME
LOG_FORMAT=json
BACKUP_RETENTION_DAYS=30

CLOUDINARY_CLOUD_NAME=REPLACE_CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY=REPLACE_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=REPLACE_CLOUDINARY_API_SECRET

STRIPE_SECRET_KEY=REPLACE_STRIPE_SECRET_KEY
STRIPE_PRICE_ID=REPLACE_STRIPE_PRICE_ID
STRIPE_WEBHOOK_SECRET=REPLACE_STRIPE_WEBHOOK_SECRET

EXPO_ACCESS_TOKEN=REPLACE_EXPO_ACCESS_TOKEN
SENTRY_DSN=REPLACE_SENTRY_DSN
OPENROUTER_API_KEY=REPLACE_OPENROUTER_API_KEY
