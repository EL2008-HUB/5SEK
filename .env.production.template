# 5SEK Production Environment Template
# Copy this file to 5second-api/.env and 5second-app/.env and fill in your values

# ============================
# BACKEND (5second-api/.env)
# ============================

NODE_ENV=production
PORT=3000
APP_ENV=production

# JWT Secret - MUST be a strong random string (min 32 chars)
JWT_SECRET=CHANGE_ME_TO_STRONG_RANDOM_SECRET_32_CHARS_MIN

# Explicit production CORS allowlist
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com

# API request body limit
API_JSON_LIMIT=1mb

# Database - PostgreSQL connection string
# For Supabase, prefer the pooler/direct URL from the dashboard and include sslmode=require.
DATABASE_URL=postgres://user:password@your-db-host:5432/fivesek?sslmode=require
DB_CONNECTION_TIMEOUT_MS=10000
DB_ACQUIRE_TIMEOUT_MS=10000
DB_QUERY_TIMEOUT_MS=15000
DB_STATEMENT_TIMEOUT_MS=15000
DB_POOL_MIN=0
DB_POOL_MAX=10

# Workers - Must be false in production for separate containers
INLINE_BACKGROUND_WORKER=false
INLINE_INJECTION_WORKER=false

# Worker polling intervals
JOB_POLL_MS=15000
JOB_SCHEDULE_MS=300000
INJECTION_INITIAL_DELAY_MS=300000
INJECTION_INTERVAL_MS=3600000
RATE_LIMIT_RETENTION_DAYS=7

# Backup retention / metrics
BACKUP_RETENTION_DAYS=30

# Cloudinary (Required for video storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Stripe (Optional - for payments)
STRIPE_SECRET_KEY=sk_test_or_live_your_key
STRIPE_PRICE_ID=price_your_price_id

# AI Service (Optional)
OPENROUTER_API_KEY=sk-or-v1-your_key

# Push Notifications (Optional)
EXPO_ACCESS_TOKEN=your_expo_token

# Error Tracking (Required)
SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0

# ============================
# FRONTEND (5second-app/.env)
# ============================

EXPO_PUBLIC_API_URL=https://api.yourdomain.com/api
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id

# Sentry Configuration
EXPO_PUBLIC_SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0
EXPO_PUBLIC_SENTRY_ENVIRONMENT=production
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
EXPO_PUBLIC_SENTRY_PROFILES_SAMPLE_RATE=0.1

# App Identifiers
EXPO_PUBLIC_IOS_BUNDLE_ID=app.fivesek.mobile
EXPO_PUBLIC_ANDROID_PACKAGE=app.fivesek.mobile

# Sentry Build Configuration
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
