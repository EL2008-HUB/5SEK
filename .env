# Development Environment Variables for 5SEK App
# Replace with your actual values

# API URL - Your backend URL
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# EAS Project ID (optional for local dev, required for builds)
EXPO_PUBLIC_EAS_PROJECT_ID=00000000-0000-0000-0000-000000000000

# Sentry Configuration (optional for local dev)
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENVIRONMENT=development
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.0
EXPO_PUBLIC_SENTRY_PROFILES_SAMPLE_RATE=0.0

# App Identifiers
EXPO_PUBLIC_IOS_BUNDLE_ID=app.fivesek.mobile
EXPO_PUBLIC_ANDROID_PACKAGE=app.fivesek.mobile
